{
  "manifest_version": 3,
  "name": "Simple Side Note",
  "version": "1.0.1",
  "description": "Chrome extension sidebar notepad",
  "permissions": ["sidePanel", "storage", "contextMenus"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open Note"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
   "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  }
}